FROM ubuntu:24.04

RUN apt-get update && apt-get install -y \
    build-essential \
    clang \
    llvm \
    libbpf-dev \
    libelf-dev \
    zlib1g-dev \
    linux-headers-generic \
    make \
    file \
    curl \
    ca-certificates \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://bun.sh/install | bash
ENV BUN_INSTALL="/root/.bun"
ENV PATH="$BUN_INSTALL/bin:$PATH"

WORKDIR /workspace

# Build:   cd ts && bun install && cd ../native && make
# API:     cd ts && bun run dev-api
# Web:     cd ts && bun run dev-web
# Tests:   cd ts && bun test
