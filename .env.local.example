# ─── aacyn Development Environment ──────────────────────────────────────────
# Copy this file to .env.local and fill in your development values.
# .env.local is gitignored — never commit real secrets.

# API authentication (leave empty to disable auth in development)
AACYN_API_KEY=

# Resend (transactional email)
RESEND_API_KEY=
EMAIL_FROM=aacyn-dev <dev@aacyn.com>

# S3/R2 cold storage
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET=

# Upstream forwarders (optional — leave empty to skip)
DATADOG_API_KEY=
DATADOG_SITE=datadoghq.com
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Node environment
NODE_ENV=development
