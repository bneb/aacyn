{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "types": ["@webgpu/types"],
        "paths": {
            "@aacyn/sdk": [
                "./packages/sdk/src/index.ts"
            ],
            "@aacyn/ui": [
                "./packages/ui/src/index.ts"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        ".next"
    ]
}