        "@opentelemetry/sdk-trace-base": "^2.6.0",
        "@sinclair/typebox": "^0.34.48",
        "elysia": "^1.2.0",
        "fzstd": "^0.1.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "protobufjs": "^8.1.0",
