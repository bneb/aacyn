{
    "name": "@aacyn/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "bin": {
        "aacyn": "./dist/cli.js"
    },
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "start": "bun run src/cli.ts",
